# Twilio credentials (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public URL of this service (used for Twilio webhook configuration)
WHATSAPP_WEBHOOK_URL=https://your-railway-domain.railway.app

# Base44 backend
BASE44_FUNCTIONS_URL=https://your-app.base44.app/functions
BASE44_API_KEY=your_base44_api_key
CHANNEL_BOT_SECRET=shared_secret_with_base44

# SQLite path (Railway: mount volume at /data)
DATABASE_PATH=/data/whatsapp-senders.db

PORT=3000
NODE_ENV=production
