# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_SECRET=random_secret_string_for_webhook_verification
TELEGRAM_WEBHOOK_URL=https://your-railway-app.railway.app/telegram/webhook

# Base44 backend
BASE44_FUNCTIONS_URL=https://your-base44-app.base44.com/functions
BASE44_API_KEY=your_base44_api_key
CHANNEL_BOT_SECRET=shared_secret_between_bot_and_base44_webhook

# Local state DB
BOT_DB_PATH=./bot-state.db

# Port (Railway sets this automatically)
PORT=3000
