# Recruiter X — environment template
# Copy to .env.local for dev, or paste into Vercel → Project → Settings →
# Environment Variables for deploy.

# ─── Supabase ──────────────────────────────────────────────────────────────
# Public — bundled into the client. Safe to expose.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Server-side only — used by import script + Edge Functions. NEVER expose to
# the browser. Do NOT prefix with VITE_.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── App branding (optional overrides) ─────────────────────────────────────
VITE_APP_NAME=Recruiter X
VITE_APP_URL=https://recruiterx.app

# ─── LLM (for AI matching / draft writing) ─────────────────────────────────
# Pick one; whichever is set will be used by src/lib/llm.js.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Stripe (commercialization phase — leave blank until Step 3 in plan) ───
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ─── Email (Postmark / Resend / SES — wire whichever you pick) ─────────────
POSTMARK_SERVER_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=noreply@talentstack.org
