# Recruiter X — environment template
#
# TWO destinations — keep them straight (see GAPS.md L20 / ARCHITECTURE.md §24):
#
#   1. PUBLIC (VITE_*)  → Vercel → Project → Settings → Environments, and
#      .env.local for dev. Vite BAKES these into the public browser bundle at
#      build time. Never put a secret behind a VITE_ prefix.
#
#   2. SECRETS          → Supabase Edge Function secrets:
#         supabase secrets set NAME=value [NAME2=value2 ...]
#      Read server-side via supabase/functions/_shared/env.ts. The healthCheck
#      function live-verifies each one returns results (see /SystemHealth).
#
# For local dev, .env.local may hold both (it is gitignored); only VITE_* vars
# reach the browser.

# ════════════════════════════════════════════════════════════════════════════
# 1. PUBLIC — Vercel env vars (+ .env.local)
# ════════════════════════════════════════════════════════════════════════════

# ─── Supabase (required) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# New-format publishable key (sb_publishable_...) or legacy anon JWT (eyJ...)
VITE_SUPABASE_ANON_KEY=sb_publishable_...your-key

# ─── App branding (optional) ───────────────────────────────────────────────
VITE_APP_NAME=Recruiter X
VITE_APP_URL=https://recruiterx.app

# ─── LiveKit browser URL (optional — video calls) ──────────────────────────
# The wss URL is public; the API key/secret are NOT (see secrets below).
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# ─── Stripe publishable key (commercialization phase) ──────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=

# ════════════════════════════════════════════════════════════════════════════
# 2. SECRETS — Supabase Edge Function secrets (NEVER prefix with VITE_)
#    supabase secrets set OPENAI_API_KEY=sk-... ANTHROPIC_API_KEY=sk-ant-...
# ════════════════════════════════════════════════════════════════════════════

# ─── Supabase service role (also used by scripts/import-csv-data.js) ───────
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── LLM providers (llmProxy + aiRecruiter* functions) ─────────────────────
# PRIMARY: Anthropic (default model claude-opus-4-8 — set in app_settings too)
ANTHROPIC_API_KEY=
# OpenAI retained ONLY for Whisper transcription (transcribeRecording)
OPENAI_API_KEY=
# Optional local model host for dev
OLLAMA_BASE_URL=

# ─── LiveKit server keys (livekitToken function) ───────────────────────────
#   supabase secrets set LIVEKIT_URL=wss://... LIVEKIT_API_KEY=API... LIVEKIT_API_SECRET=...
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Email provider (either one; sendApprovedDraft / followups) ────────────
POSTMARK_SERVER_TOKEN=
RESEND_API_KEY=
EMAIL_FROM=noreply@talentstack.org

# ─── Cron gating (scheduledFollowupRun; required in production) ────────────
CRON_SECRET=

# ─── Stripe (commercialization phase) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
